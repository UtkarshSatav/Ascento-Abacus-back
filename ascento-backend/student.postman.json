{
  "info": {
    "name": "Ascento Student API Collection",
    "description": "Student onboarding and student app APIs with first-login password change flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://ascento-abacus-backend.onrender.com/api" },
    { "key": "adminEmail", "value": "admin@school.com" },
    { "key": "adminPassword", "value": "admin@123" },
    { "key": "adminSessionKey", "value": "" },
    { "key": "domainId", "value": "" },
    { "key": "suffix", "value": "{{$timestamp}}" },
    { "key": "studentId", "value": "" },
    { "key": "studentLoginEmail", "value": "" },
    { "key": "studentTempPassword", "value": "" },
    { "key": "studentNewPassword", "value": "Student@123" },
    { "key": "studentSessionKey", "value": "" }
  ],
  "item": [
    {
      "name": "01 Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('adminSessionKey', json.data.sessionKey);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/admin/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        }
      }
    },
    {
      "name": "02 Get Domain",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "const domains = json?.data?.data || [];",
              "if (domains.length) pm.collectionVariables.set('domainId', domains[0]._id);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "x-session-key", "value": "{{adminSessionKey}}" }],
        "url": "{{baseUrl}}/admin/domains?limit=1"
      }
    },
    {
      "name": "03 Create Student By Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('studentId', json.data.student._id || json.data.student.id);",
              "pm.collectionVariables.set('studentLoginEmail', json.data.studentLoginEmail);",
              "pm.collectionVariables.set('studentTempPassword', json.data.temporaryPassword);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-session-key", "value": "{{adminSessionKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/admin/students",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Test Student {{suffix}}\",\n  \"parentName\": \"Test Parent\",\n  \"parentPhone\": \"9999999999\",\n  \"parentEmail\": \"test.student.{{suffix}}@school.com\",\n  \"domainId\": \"{{domainId}}\",\n  \"gender\": \"male\",\n  \"dateOfBirth\": \"2012-01-01\",\n  \"address\": \"123 Test Lane\",\n  \"city\": \"Bhopal\",\n  \"state\": \"Madhya Pradesh\",\n  \"bloodGroup\": \"O+\"\n}"
        }
      }
    },
    {
      "name": "04 Student Login With Temporary Password",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('studentSessionKey', json.data.sessionKey);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"{{studentLoginEmail}}\",\n  \"password\": \"{{studentTempPassword}}\",\n  \"role\": \"student\"\n}"
        }
      }
    },
    {
      "name": "05 Student Change Password (first login)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-session-key", "value": "{{studentSessionKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/student/change-password",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"{{studentTempPassword}}\",\n  \"newPassword\": \"{{studentNewPassword}}\"\n}"
        }
      }
    },
    {
      "name": "06 Student Login With New Password",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('studentSessionKey', json.data.sessionKey);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"{{studentLoginEmail}}\",\n  \"password\": \"{{studentNewPassword}}\",\n  \"role\": \"student\"\n}"
        }
      }
    },
    {
      "name": "07 Auth Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-session-key", "value": "{{studentSessionKey}}" }],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "08 Current Class",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-session-key", "value": "{{studentSessionKey}}" }],
        "url": "{{baseUrl}}/student/current-class"
      }
    },
    {
      "name": "09 Attendance",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-session-key", "value": "{{studentSessionKey}}" }],
        "url": "{{baseUrl}}/student/attendance"
      }
    },
    {
      "name": "10 Dashboard",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-session-key", "value": "{{studentSessionKey}}" }],
        "url": "{{baseUrl}}/student/dashboard"
      }
    },
    {
      "name": "11 Homework",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-session-key", "value": "{{studentSessionKey}}" }],
        "url": "{{baseUrl}}/student/homework"
      }
    },
    {
      "name": "12 Exams",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-session-key", "value": "{{studentSessionKey}}" }],
        "url": "{{baseUrl}}/student/exams"
      }
    },
    {
      "name": "13 Marks",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-session-key", "value": "{{studentSessionKey}}" }],
        "url": "{{baseUrl}}/student/marks"
      }
    },
    {
      "name": "14 Report Card",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-session-key", "value": "{{studentSessionKey}}" }],
        "url": "{{baseUrl}}/student/report-card"
      }
    },
    {
      "name": "15 Fees",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-session-key", "value": "{{studentSessionKey}}" }],
        "url": "{{baseUrl}}/student/fees"
      }
    },
    {
      "name": "16 Timetable",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-session-key", "value": "{{studentSessionKey}}" }],
        "url": "{{baseUrl}}/student/timetable"
      }
    }
  ]
}
