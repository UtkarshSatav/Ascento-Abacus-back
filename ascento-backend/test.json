{
  "info": {
    "name": "Ascento Admin API Priority Test Collection",
    "description": "Admin-only API test flow in dependency order. Set baseUrl and run folders top to bottom.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" },
    { "key": "adminEmail", "value": "admin@school.com" },
    { "key": "adminPassword", "value": "admin@123" },
    { "key": "sessionKey", "value": "" },
    { "key": "domainId", "value": "" },
    { "key": "classId", "value": "" },
    { "key": "sectionId", "value": "" },
    { "key": "subjectId", "value": "" },
    { "key": "teacherId", "value": "" },
    { "key": "academicYearId", "value": "" },
    { "key": "examId", "value": "" },
    { "key": "examSubjectId", "value": "" },
    { "key": "assignmentId", "value": "" },
    { "key": "feeId", "value": "" },
    { "key": "enquiryId", "value": "" },
    { "key": "existingStudentId", "value": "" },
    { "key": "existingEnquiryId", "value": "" }
  ],
  "item": [
    {
      "name": "00 - Admin Auth",
      "item": [
        {
          "name": "01 Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('sessionKey', json.data.sessionKey);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/admin/login"
          }
        },
        {
          "name": "02 Admin Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/profile"
          }
        }
      ]
    },
    {
      "name": "01 - Core Masters (Create in order)",
      "item": [
        {
          "name": "01 Create Domain",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('domainId', json.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Science\",\n  \"code\": \"SCI\",\n  \"description\": \"Science stream\",\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/admin/domains"
          }
        },
        {
          "name": "02 Create Class",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('classId', json.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Class 8\",\n  \"domainId\": \"{{domainId}}\",\n  \"description\": \"Class 8 section\"\n}"
            },
            "url": "{{baseUrl}}/admin/classes"
          }
        },
        {
          "name": "03 Create Section",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('sectionId', json.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Section A\",\n  \"classId\": \"{{classId}}\"\n}"
            },
            "url": "{{baseUrl}}/admin/sections"
          }
        },
        {
          "name": "04 Create Subject",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('subjectId', json.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mathematics\",\n  \"code\": \"MATH-8\",\n  \"classId\": \"{{classId}}\",\n  \"description\": \"Math for class 8\"\n}"
            },
            "url": "{{baseUrl}}/admin/subjects"
          }
        },
        {
          "name": "05 Create Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('teacherId', json.data.teacher._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Created Teacher\",\n  \"email\": \"teacher.{{$timestamp}}@school.com\",\n  \"phone\": \"9999999999\",\n  \"domainId\": \"{{domainId}}\"\n}"
            },
            "url": "{{baseUrl}}/admin/teachers"
          }
        },
        {
          "name": "06 Assign Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('assignmentId', json.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teacherId\": \"{{teacherId}}\",\n  \"classId\": \"{{classId}}\",\n  \"sectionId\": \"{{sectionId}}\",\n  \"subjectId\": \"{{subjectId}}\",\n  \"academicYear\": \"2026-2027\",\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/admin/assign-teacher"
          }
        }
      ]
    },
    {
      "name": "02 - Academic Setup",
      "item": [
        {
          "name": "01 Create Academic Year",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('academicYearId', json.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"2026-2027\",\n  \"startDate\": \"2026-04-01\",\n  \"endDate\": \"2027-03-31\",\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/admin/academic-years"
          }
        },
        {
          "name": "02 Create Exam",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('examId', json.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"examName\": \"Mid Term\",\n  \"classId\": \"{{classId}}\",\n  \"academicYearId\": \"{{academicYearId}}\",\n  \"examStartDate\": \"2026-09-10\",\n  \"examEndDate\": \"2026-09-20\",\n  \"description\": \"Mid term exams\",\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/admin/exams"
          }
        },
        {
          "name": "03 Create Exam Subject",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('examSubjectId', json.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"examId\": \"{{examId}}\",\n  \"subjectId\": \"{{subjectId}}\",\n  \"totalMarks\": 100,\n  \"passingMarks\": 35,\n  \"examDate\": \"2026-09-15\",\n  \"startTime\": \"09:00\",\n  \"endTime\": \"12:00\"\n}"
            },
            "url": "{{baseUrl}}/admin/exam-subject"
          }
        }
      ]
    },
    {
      "name": "03 - Admin Operations",
      "item": [
        {
          "name": "01 Create Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Annual Day\",\n  \"description\": \"Cultural event\",\n  \"eventDate\": \"2026-12-20\",\n  \"location\": \"Main Auditorium\",\n  \"attachments\": []\n}"
            },
            "url": "{{baseUrl}}/admin/events"
          }
        },
        {
          "name": "02 Create Reminder (Class Target)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Class Test Reminder\",\n  \"description\": \"Weekly test on Friday\",\n  \"targetType\": \"class\",\n  \"targetId\": \"{{classId}}\",\n  \"reminderDate\": \"2026-04-16\"\n}"
            },
            "url": "{{baseUrl}}/admin/reminders"
          }
        },
        {
          "name": "03 Create Notification (Broadcast)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"System Maintenance\",\n  \"message\": \"Portal will be down from 10 PM to 11 PM\",\n  \"targetType\": \"broadcast\",\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/admin/notifications"
          }
        },
        {
          "name": "04 Create Fee (requires existingStudentId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('feeId', json.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"{{existingStudentId}}\",\n  \"classId\": \"{{classId}}\",\n  \"academicYearId\": \"{{academicYearId}}\",\n  \"feeType\": \"tuition\",\n  \"amount\": 15000,\n  \"dueDate\": \"2026-06-30\",\n  \"paymentStatus\": \"pending\"\n}"
            },
            "url": "{{baseUrl}}/admin/fees"
          }
        },
        {
          "name": "05 Mark Fee Paid (optional)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"feeId\": \"{{feeId}}\",\n  \"paymentMethod\": \"upi\",\n  \"transactionReference\": \"TXN-ADMIN-001\",\n  \"paymentDate\": \"2026-04-01\"\n}"
            },
            "url": "{{baseUrl}}/admin/fees/pay"
          }
        },
        {
          "name": "06 List Enquiries",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/enquiries"
          }
        },
        {
          "name": "07 Update Enquiry (requires existingEnquiryId)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in-progress\",\n  \"message\": \"Follow-up initiated by admin\"\n}"
            },
            "url": "{{baseUrl}}/admin/enquiries/{{existingEnquiryId}}"
          }
        }
      ]
    },
    {
      "name": "04 - Admin Analytics",
      "item": [
        {
          "name": "01 Get Dashboard",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/dashboard"
          }
        }
      ]
    },
    {
      "name": "05 - Verification Lists",
      "item": [
        {
          "name": "01 List Domains",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/domains"
          }
        },
        {
          "name": "02 List Classes",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/classes"
          }
        },
        {
          "name": "03 List Sections",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/sections?classId={{classId}}"
          }
        },
        {
          "name": "04 List Subjects",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/subjects?classId={{classId}}"
          }
        },
        {
          "name": "05 List Teachers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/teachers"
          }
        },
        {
          "name": "06 List Teacher Assignments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/teacher-assignments"
          }
        },
        {
          "name": "07 List Academic Years",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/academic-years"
          }
        },
        {
          "name": "08 List Exams",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/exams?classId={{classId}}&academicYearId={{academicYearId}}"
          }
        },
        {
          "name": "09 List Exam Subjects",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/exam-subjects/{{examId}}"
          }
        },
        {
          "name": "10 List Fees",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-session-key", "value": "{{sessionKey}}" }
            ],
            "url": "{{baseUrl}}/admin/fees"
          }
        }
      ]
    }
  ]
}
